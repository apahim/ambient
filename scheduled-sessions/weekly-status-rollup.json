{
  "schedule": "0 14 * * 5",
  "displayName": "GCP HCP Weekly Status Rollup",
  "sessionRequest": {
    "task": "Run the weekly status rollup workflow.",
    "displayName": "Weekly Status Rollup",
    "model": "claude-sonnet-4-20250514",
    "timeout": 2400,
    "stopOnRunFinished": true,
    "repos": [
      {
        "url": "https://github.com/apahim/ambient",
        "branch": "main",
        "autoPush": true
      },
      {
        "url": "https://github.com/apahim/gcp-hcp",
        "branch": "main",
        "autoPush": false
      }
    ],
    "activeWorkflow": {
      "gitUrl": "https://github.com/apahim/ambient",
      "branch": "main",
      "path": "workflows/health-check-status-rollup"
    },
    "mcpServers": {
      "custom": {
        "atlassian": {
          "command": "npx",
          "args": ["-y", "@anthropic/mcp-atlassian"],
          "env": {
            "JIRA_URL": "https://redhat.atlassian.net",
            "JIRA_USERNAME": "${JIRA_USERNAME}",
            "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
          }
        }
      }
    },
    "environmentVariables": {
      "JIRA_EMAIL": "asegundo@redhat.com"
    },
    "labels": {
      "team": "gcp-hcp",
      "stage": "1",
      "activity": "9"
    }
  }
}
