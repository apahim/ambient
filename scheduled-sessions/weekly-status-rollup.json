{
  "schedule": "0 14 * * 5",
  "displayName": "GCP HCP Weekly Status Rollup",
  "suspend": false,
  "reuseLastSession": false,
  "sessionTemplate": {
    "initialPrompt": "Run the weekly status rollup workflow.",
    "displayName": "Weekly Status Rollup",
    "llmSettings": {
      "model": "claude-sonnet-4-5",
      "temperature": 0,
      "maxTokens": 8192
    },
    "timeout": 2400,
    "inactivityTimeout": 300,
    "stopOnRunFinished": true,
    "repos": [
      {
        "url": "https://github.com/apahim/ambient",
        "branch": "main",
        "autoPush": true
      },
      {
        "url": "https://github.com/apahim/gcp-hcp",
        "branch": "main",
        "autoPush": false
      }
    ],
    "activeWorkflow": {
      "gitUrl": "https://github.com/apahim/ambient",
      "branch": "main",
      "path": "workflows/health-check-status-rollup"
    },
    "environmentVariables": {
      "JIRA_EMAIL": "asegundo@redhat.com"
    },
    "labels": {
      "team": "gcp-hcp",
      "stage": "1",
      "activity": "9"
    }
  }
}
